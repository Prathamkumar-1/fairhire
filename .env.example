GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
VERTEX_AI_LOCATION=us-central1
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your_project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
BACKEND_URL=https://fairhire-backend-xxxx-uc.a.run.app

# Security (Area 4)
# Comma-separated list of allowed CORS origins. Defaults to production frontend + localhost.
ALLOWED_ORIGINS=https://fairhire-6b3d4.web.app,https://fairhire-6b3d4.firebaseapp.com,http://localhost:8000,http://localhost:3000
# Set to "true" to enforce Firebase ID token verification on all endpoints.
REQUIRE_AUTH=false
